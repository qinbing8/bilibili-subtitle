# 阿里云通义听悟（必填，全部 3 个）
ALI_ACCESS_KEY_ID=
ALI_ACCESS_KEY_SECRET=
ALI_APP_KEY=

# 通义听悟语言（可选，默认 auto）
LANGUAGE=auto

# 通义千问（DashScope，用于 B 站字幕的 AI 排版；与听悟密钥不同）
DASHSCOPE_API_KEY=

# 共享访问密码（必填，用户在登录页输入此密码）
APP_ACCESS_PASSWORD=

# B 站 SESSDATA Cookie（可选，但建议配；不配的视频可能拿不到高清音频）
BILIBILI_SESSDATA=

# CORS 允许的来源（可选，逗号分隔）
ALLOWED_ORIGINS=https://your-project.vercel.app,http://localhost:5173

# 本地后端端口（可选，默认 9091；若 9090 被代理工具占用，建议显式设置）
BACKEND_PORT=9091

# 元数据签名密钥（可选；用于下载 docx/txt 的元信息签名）
META_TOKEN_SECRET=

# 音频公网代理（必填，用于让通义听悟回拉 B 站音频）
# 推荐：在独立终端运行 cloudflared tunnel --url http://localhost:9091
# 然后把输出的 https://*.trycloudflare.com 填到下面（不要带末尾斜杠）
PUBLIC_PROXY_BASE_URL=

# 音频代理 token 签名密钥（建议 32 字节随机串；生产环境不要复用 META_TOKEN_SECRET）
AUDIO_PROXY_TOKEN_SECRET=

# 音频代理 token 有效期（秒，默认 1800，最大 1800）
AUDIO_PROXY_TOKEN_TTL_SEC=1800

# 音频代理滥用控制（可选；默认单 token 并发 1、全局并发 4、单 token 500MB、30 分钟）
AUDIO_PROXY_MAX_CONCURRENT_PER_TOKEN=1
AUDIO_PROXY_MAX_CONCURRENT_GLOBAL=4
AUDIO_PROXY_MAX_BYTES_PER_TOKEN=524288000
AUDIO_PROXY_MAX_DURATION_MS=1800000

# 允许代理回源的 host 正则（逗号分隔；留空时使用内置 B 站 CDN 列表）
AUDIO_PROXY_ALLOWED_HOSTS=
